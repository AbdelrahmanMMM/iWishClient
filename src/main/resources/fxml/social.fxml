<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <TextField fx:id="searchField" layoutX="300.0" layoutY="26.0" prefHeight="26.0" prefWidth="200.0" />
      <Button layoutX="518.0" layoutY="26.0" mnemonicParsing="false" onAction="#handleSearch" text="Search" />
      <ListView fx:id="resultsList" layoutX="300.0" layoutY="92.0" prefHeight="67.0" prefWidth="200.0" />
      <Button layoutX="506.0" layoutY="174.0" mnemonicParsing="false" onAction="#handleAddFriend" text="Add Friend" />
      <ListView fx:id="pendingRequestsList" layoutX="300.0" layoutY="290.0" prefHeight="83.0" prefWidth="200.0" />
      <Button layoutX="514.0" layoutY="291.0" mnemonicParsing="false" onAction="#handleAcceptRequest" text="Accept" />
      <Button layoutX="516.0" layoutY="348.0" mnemonicParsing="false" onAction="#handleDeclineRequest" text="Decline" />
      <ListView fx:id="friendsList" layoutX="33.0" layoutY="26.0" prefHeight="350.0" prefWidth="200.0" />
   </children>
</AnchorPane>
