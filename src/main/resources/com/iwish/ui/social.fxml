<AnchorPane id="AnchorPane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iwish.controllers.SocialController">
   <children>
      <SplitPane dividerPositions="0.5346205059920106" prefHeight="402.0" prefWidth="602.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <items>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
               <children>
                  <VBox layoutX="10.0" prefHeight="402.0" prefWidth="298.0">
                     <children>
                        <Label text="My Friends" />
                        <ListView fx:id="friendsList" prefHeight="274.0" prefWidth="100.0" VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
               <children>
                  <VBox layoutX="13.0" layoutY="14.0" prefHeight="391.0" prefWidth="254.0" spacing="10.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                     <children>
                        <HBox prefHeight="30.0" prefWidth="234.0">
                           <children>
                              <TextField fx:id="searchField" HBox.hgrow="ALWAYS" />
                              <Button mnemonicParsing="false" onAction="#handleSearch" text="Search" />
                           </children>
                        </HBox>
                        <ListView fx:id="resultsList" prefHeight="55.0" prefWidth="168.0" />
                        <Button mnemonicParsing="false" onAction="#handleAddFriend" text="Add Friend" />
                        <Separator prefWidth="200.0" />
                        <Label text="Pending Requsts" />
                        <ListView fx:id="pendingRequestsList" prefHeight="114.0" prefWidth="234.0" />
                        <HBox prefHeight="40.0" prefWidth="234.0">
                           <children>
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAcceptRequest" text="Accept" HBox.hgrow="ALWAYS" />
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDeclineRequest" text="Decline" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
        </items>
      </SplitPane>
   </children>
</AnchorPane>
